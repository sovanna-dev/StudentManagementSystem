@model List<Student>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible
                    fade show mx-3 mt-3" role="alert">
        <i class="bi bi-check-circle-fill"></i>
        @TempData["Success"]
        <button type="button" class="btn-close"
                data-bs-dismiss="alert"></button>
    </div>
}

<div class="container mt-4">
    <div class="d-flex justify-content-between
                align-items-center mb-3">
        <h3 class="fw-bold">
            <i class="bi bi-people-fill text-primary"></i>
            Students
        </h3>
        <a asp-action="Create"
           class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Student
        </a>
    </div>

    <!-- Search Bar -->
    <form method="get" class="mb-3">
        <div class="input-group">
            <input type="text" name="search"
                   value="@ViewBag.Search"
                   class="form-control"
                   placeholder="Search by name or class..." />
            <button class="btn btn-outline-primary"
                    type="submit">
                <i class="bi bi-search"></i> Search
            </button>
            @if (!string.IsNullOrEmpty(ViewBag.Search))
            {
                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    <i class="bi bi-x"></i> Clear
                </a>
            }
        </div>
    </form>

    <!-- Student Cards -->
    <div class="row g-3">
        @foreach (var s in Model)
        {
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <!-- Avatar -->
                        <div class="d-flex align-items-center
                                        gap-3 mb-3">
                            <div class="rounded-circle d-flex
                                    align-items-center
                                    justify-content-center fw-bold
                                    text-white"
                                 style="width:48px;height:48px;
                                    font-size:18px;
                                    background:@(s.Gender == "Female"
                                                                     ? "#d63384" : "#0d6efd")">
                            @s.FullName.Substring(0, 1)
                        </div>
                        <div>
                            <h6 class="mb-0 fw-bold">
                                @s.FullName
                            </h6>
                            <small class="text-muted">
                                @s.ClassRoom
                            </small>
                        </div>
                    </div>

                        <p class="mb-1 text-muted small">
                            <i class="bi bi-envelope"></i>
                            @s.Email
                        </p>
                        <p class="mb-1 text-muted small">
                            <i class="bi bi-phone"></i>
                            @s.Phone
                        </p>
                        <p class="mb-3">
                            <span class="badge bg-@(s.Gender == "Female"
                                                              ? "pink" : "primary")"
                              style="background:@(s.Gender == "Female"
                                                              ? "#d63384" : "#0d6efd")!important">
                            <i class="bi bi-person"></i>
                            @s.Gender
                        </span>
                    </p>
                </div>
                <div class="card-footer bg-transparent
                                d-flex gap-2">
                    <a asp-action="Details"
                       asp-route-id="@s.ID"
                       class="btn btn-sm btn-outline-info flex-fill">
                        <i class="bi bi-eye"></i> View
                    </a>
                    <a asp-action="Edit"
                       asp-route-id="@s.ID"
                       class="btn btn-sm btn-outline-warning flex-fill">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <a asp-action="Delete"
                       asp-route-id="@s.ID"
                       onclick="return confirm('Delete @s.FullName?')"
                       class="btn btn-sm btn-outline-danger flex-fill">
                        <i class="bi bi-trash"></i> Delete
                    </a>
                </div>
            </div>
        </div>
                }
    </div>

    <p class="text-muted mt-3 small">
        Total: @Model.Count student(s)
    </p>
</div>
