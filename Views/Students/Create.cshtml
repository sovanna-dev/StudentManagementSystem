@model Student

<div class="container mt-4" style="max-width:600px">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">
                <i class="bi bi-person-plus-fill"></i>
                Add New Student
            </h5>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Full Name
                    </label>
                    <input asp-for="FullName"
                           class="form-control"
                           placeholder="Enter full name" />
                    <span asp-validation-for="FullName"
                          class="text-danger small"></span>
                </div>

                <div class="row mb-3">
                    <div class="col">
                        <label class="form-label fw-bold">
                            Gender
                        </label>
                        <select asp-for="Gender"
                                class="form-select">
                            <option value="">-- Select --</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                        </select>
                    </div>
                    <div class="col">
                        <label class="form-label fw-bold">
                            Date of Birth
                        </label>
                        <input asp-for="DateOfBirth"
                               type="date"
                               class="form-control" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Email
                    </label>
                    <input asp-for="Email"
                           class="form-control"
                           placeholder="email@example.com" />
                </div>

                <div class="row mb-3">
                    <div class="col">
                        <label class="form-label fw-bold">
                            Phone
                        </label>
                        <input asp-for="Phone"
                               class="form-control"
                               placeholder="012xxxxxx" />
                    </div>
                    <div class="col">
                        <label class="form-label fw-bold">
                            Class
                        </label>
                        <select asp-for="ClassRoom"
                                class="form-select">
                            <option value="">-- Select --</option>
                            <option value="CS-A">CS-A</option>
                            <option value="CS-B">CS-B</option>
                            <option value="CS-C">CS-C</option>
                        </select>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit"
                            class="btn btn-primary flex-fill">
                        <i class="bi bi-save"></i> Save Student
                    </button>
                    <a asp-action="Index"
                       class="btn btn-outline-secondary flex-fill">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
