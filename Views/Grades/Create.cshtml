@using StSudentManagementSystem.Models
@model Grade

<div class="container mt-4" style="max-width:500px">
    <div class="card shadow-sm">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">
                <i class="bi bi-plus-circle"></i>
                Add Grade
            </h5>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Student
                    </label>
                    <select asp-for="StudentID"
                            class="form-select">
                        <option value="">-- Select Student --</option>
                        @foreach (var s in
                                                (List<Student>)ViewBag.Students)
                        {
                            <option value="@s.ID">
                                @s.FullName (@s.ClassRoom)
                            </option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Subject
                    </label>
                    <select asp-for="SubjectID"
                            class="form-select">
                        <option value="">-- Select Subject --</option>
                        @foreach (var sub in
                                                (List<Subject>)ViewBag.Subjects)
                        {
                            <option value="@sub.ID">
                                @sub.SubjectName
                            </option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Score (0-100)
                    </label>
                    <input asp-for="Score"
                           type="number"
                           min="0" max="100"
                           step="0.5"
                           class="form-control"
                           placeholder="e.g. 92.5" />
                    <div class="form-text">
                        A=90+ | B+=80+ | B=70+ | C=60+ | F=below 60
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit"
                            class="btn btn-success flex-fill">
                        <i class="bi bi-save"></i> Save Grade
                    </button>
                    <a asp-action="Index"
                       class="btn btn-outline-secondary flex-fill">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
