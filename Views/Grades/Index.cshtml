@model List<Grade>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible
                    fade show mx-3 mt-3">
        <i class="bi bi-check-circle-fill"></i>
        @TempData["Success"]
        <button type="button" class="btn-close"
                data-bs-dismiss="alert"></button>
    </div>
}

<div class="container mt-4">
    <div class="d-flex justify-content-between
                align-items-center mb-3">
        <h3 class="fw-bold">
            <i class="bi bi-bar-chart-fill text-success"></i>
            Grade Management
        </h3>
        <a asp-action="Create"
           class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Add Grade
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Student</th>
                        <th>Subject</th>
                        <th>Score</th>
                        <th>Grade</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @{int i = 1;}
                    @foreach (var g in Model)
                    {
                        <tr>
                            <td>@i++</td>
                            <td>
                                <strong>@g.Student.FullName</strong>
                                <br/>
                                <small class="text-muted">
                                    @g.Student.ClassRoom
                                </small>
                            </td>
                            <td>@g.Subject.SubjectName</td>
                            <td>
                                <div class="progress" 
                                     style="height:20px;width:100px">
                                    <div class="progress-bar 
                                        bg-@(g.Score >= 80 ? "success" 
                                            : g.Score >= 60 ? "warning" 
                                            : "danger")"
                                         style="width:@g.Score%">
                                        @g.Score
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge fs-6
                                    bg-@(g.GradeLetter == "A" ? "success"
                                        : g.GradeLetter == "B+" || 
                                          g.GradeLetter == "B" ? "primary"
                                        : g.GradeLetter == "C" ? "warning"
                                        : "danger")">
                                    @g.GradeLetter
                                </span>
                            </td>
                            <td>
                                <a asp-action="Delete"
                                   asp-route-id="@g.ID"
                                   onclick="return confirm('Delete this grade?')"
                                   class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
