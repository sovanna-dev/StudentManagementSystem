@model Attendance

<div class="container mt-4" style="max-width:450px">
    <div class="card shadow-sm">
        <div class="card-header bg-warning">
            <h5 class="mb-0">
                <i class="bi bi-calendar-plus"></i>
                Record Attendance
            </h5>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Student
                    </label>
                    <select asp-for="StudentID"
                            class="form-select">
                        <option value="">
                            -- Select Student --
                        </option>
                        @foreach (var s in
                                                (List<Student>)ViewBag.Students)
                        {
                            <option value="@s.ID">
                                @s.FullName (@s.ClassRoom)
                            </option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Date
                    </label>
                    <input asp-for="Date"
                           type="date"
                           class="form-control"
                           value="@DateTime.Now
                                  .ToString(" yyyy-MM-dd")" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Status
                    </label>
                    <div class="d-flex gap-3">
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="radio"
                                   asp-for="Status"
                                   value="Present"
                                   id="present" />
                            <label class="form-check-label
                                          text-success fw-bold"
                                   for="present">
                                Present
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="radio"
                                   asp-for="Status"
                                   value="Absent"
                                   id="absent" />
                            <label class="form-check-label
                                          text-danger fw-bold"
                                   for="absent">
                                Absent
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="radio"
                                   asp-for="Status"
                                   value="Late"
                                   id="late" />
                            <label class="form-check-label
                                          text-warning fw-bold"
                                   for="late">
                                Late
                            </label>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit"
                            class="btn btn-warning flex-fill">
                        <i class="bi bi-save"></i> Save
                    </button>
                    <a asp-action="Index"
                       class="btn btn-outline-secondary flex-fill">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
